{
  "manifest_version": 3,
  "name": "Walmart AirPods Price Tracker",
  "version": "1.0",
  "description": "Monitors AirPods Pro 3 price on Walmart and alerts when below $250",
  "permissions": [
    "alarms",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://www.walmart.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end",
      "exclude_matches": ["https://www.walmart.com/ip/AirPods-Pro-3/17835006350*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
